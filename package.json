{
  "name": "magi-showcase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack-sdk": "bash scripts/pack-sdk.sh",
    "refresh-sdk": "bash scripts/pack-sdk.sh",
    "sync-snippets": "tsx scripts/sync-snippets.ts"
  },
  "dependencies": {
    "@aioha/aioha": "^1.8.2",
    "@hiveio/dhive": "^1.3.2",
    "@vsc.eco/crosschain-core": "link:../crosschain-sdk/packages/core",
    "@vsc.eco/crosschain-sdk": "link:../crosschain-sdk/packages/sdk",
    "@vsc.eco/crosschain-widget": "link:../crosschain-sdk/packages/widget",
    "highlight.js": "^11.11.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "pnpm": {
    "overrides": {
      "@vsc.eco/crosschain-core": "link:../crosschain-sdk/packages/core",
      "@vsc.eco/crosschain-sdk": "link:../crosschain-sdk/packages/sdk",
      "@vsc.eco/crosschain-widget": "link:../crosschain-sdk/packages/widget"
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "shiki": "^1.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
